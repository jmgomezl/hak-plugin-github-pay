# Hedera account credentials (get from https://portal.hedera.com)
# This account is the PAYER — it funds the bounty transfers.
HEDERA_ACCOUNT_ID=0.0.XXXXXX
HEDERA_PRIVATE_KEY=302e...

# Network: testnet (default) or mainnet
HEDERA_NETWORK=testnet

# Google AI Studio API key for Gemini 2.5 Flash (get from https://aistudio.google.com)
GEMINI_API_KEY=AIza...

# Shared secret configured in the GitHub webhook settings.
# Used to validate the X-Hub-Signature-256 HMAC on every incoming payload.
GITHUB_WEBHOOK_SECRET=replace-with-a-long-random-string

# Optional: GitHub token used by seal_release_provenance to fetch private release assets.
# Public repos work without it.
GITHUB_TOKEN=

# Optional: Slack/Teams incoming-webhook URL. If set, a notification is posted
# on every successful payment (PR link, contributor, HBAR amount, Hashscan URL).
SLACK_WEBHOOK_URL=

# Port for the Express webhook server
PORT=3000
